  "_meta": {
    "purpose": "Golden cases que CONGELAN el comportamiento actual de la IA (v339) antes del refactor. Sirven de red de seguridad: si una migración de ruteo cambia una respuesta, esto lo caza.",
    "fields": {
      "q": "pregunta del usuario (español colombiano)",
      "expectedIntent": "intent(s) aceptable(s) de aiClassifyIntent. Array = cualquiera vale. null = no se valida intent.",
      "expectedRoute": "ruta declarada esperada (informativo: se compara con la ruta del registry, NO con el guard real de la cascada).",
      "mustContain": "subcadenas que DEBEN aparecer (case-insensitive). Conservadoras a propósito.",
      "mustNotContain": "subcadenas que NO deben aparecer.",
      "shouldUseRealData": "true si la respuesta debe incluir una cifra de datos reales ($).",
      "shouldUseLegacy": "false para rutas que NO deberían caer al fallback clásico (informativo en v1).",
      "note": "contexto del caso"
    },
    "assertion_policy": "HARD: expectedIntent, mustContain, mustNotContain, shouldUseRealData. SOFT (warn): expectedRoute, shouldUseLegacy — la traza v1 no conoce el guard exacto."
  },
