{
  "name": "mi-turno",
  "version": "1.0.0",
  "description": "PWA de gestión de turnos y nómina para Colombia",
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 8000 --bind 0.0.0.0",
    "serve": "npx http-server -p 8000 -c-1",
    "deploy": "echo 'Deploy to Vercel/Netlify manually or via CI'",
    "lint": "eslint 'js/**/*.js'",
    "lint:fix": "eslint 'js/**/*.js' --fix",
    "format": "prettier --write 'js/**/*.js' 'css/**/*.css' 'supabase/**/*.ts'",
    "format:check": "prettier --check 'js/**/*.js' 'css/**/*.css' 'supabase/**/*.ts'",
    "test:smoke": "node tests/smoke.cjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "node tests/a11y.mjs",
    "test": "npm run test:smoke && npm run test:e2e",
    "prepare": "husky",
    "test:ai-browser": "node tests/ai-browser.mjs",
    "test:coverage": "node tests/ai-coverage.mjs",
    "test:benchmark": "node tests/ai-benchmark.mjs",
    "test:golden": "node tests/ai/ai-golden-runner.js"
  },
  "lint-staged": {
    "js/**/*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "css/**/*.css": [
      "prettier --write"
    ],
    "supabase/**/*.ts": [
      "prettier --write"
    ]
  },
  "keywords": [
    "turnos",
    "nomina",
    "colombia",
    "pwa",
    "trabajo",
    "recargos",
    "horas-extras"
  ],
  "author": "Mi Turno",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aedincen-rgb/mi-turno-BETA.git"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "axe-core": "^4.12.0",
    "chart.js": "^4.5.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
